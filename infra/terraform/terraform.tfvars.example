aws_region   = "us-east-1"
project_name = "synth-nova"
environment  = "hackathon"
app_image_uri = "123456789012.dkr.ecr.us-east-1.amazonaws.com/synth-nova-hackathon-app:latest"

# Optional: leave networking blank to let Terraform create a VPC and subnets.
vpc_id             = ""
public_subnet_ids  = []
private_subnet_ids = []

# Optional: leave URLs blank to let Terraform use the ALB DNS name.
nextauth_url        = ""
next_public_app_url = ""

# Optional: leave blank to auto-generate a strong DB password.
db_password = ""

# Optional overrides
bedrock_nova_text_model_id = "amazon.nova-lite-v1:0"
bedrock_nova_fast_model_id = "amazon.nova-micro-v1:0"
transcribe_language_code   = "en-US"
