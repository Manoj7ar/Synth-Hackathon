generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  passwordHash          String?
  role                  String
  name                  String?
  practiceName          String?
  specialty             String?
  onboardingCompletedAt DateTime?
  createdAt             DateTime  @default(now())

  clinicianVisits       Visit[]                @relation("ClinicianVisits")
  appointments          Appointment[]          @relation("ClinicianAppointments")
  carePlanItems         CarePlanItem[]         @relation("ClinicianCarePlanItems")
  generatedReports      GeneratedReport[]      @relation("ClinicianGeneratedReports")
  reconciliationRuns    ReconciliationRun[]    @relation("ClinicianReconciliationRuns")
  reconciliationActions ReconciliationAction[] @relation("ClinicianReconciliationActions")
}

model Patient {
  id          String    @id @default(cuid())
  displayName String
  dateOfBirth DateTime?
  createdAt   DateTime  @default(now())

  visits                Visit[]
  shareLinks            ShareLink[]
  appointments          Appointment[]
  carePlanItems         CarePlanItem[]
  generatedReports      GeneratedReport[]
  reconciliationRuns    ReconciliationRun[]
  reconciliationActions ReconciliationAction[]
}

model Visit {
  id             String    @id @default(cuid())
  patientId      String
  clinicianId    String
  status         String
  chiefComplaint String?
  startedAt      DateTime  @default(now())
  finalizedAt    DateTime?

  patient               Patient                @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinician             User                   @relation("ClinicianVisits", fields: [clinicianId], references: [id])
  shareLinks            ShareLink[]
  documentation         VisitDocumentation?
  artifacts             VisitArtifact[]
  appointments          Appointment[]
  carePlanItems         CarePlanItem[]
  generatedReports      GeneratedReport[]
  reconciliationRuns    ReconciliationRun[]
  reconciliationActions ReconciliationAction[]

  @@index([patientId])
  @@index([clinicianId])
  @@index([status])
}

model VisitDocumentation {
  id              String   @id @default(cuid())
  visitId         String   @unique
  transcriptJson  String
  summary         String
  soapNotes       String
  additionalNotes String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
}

model VisitArtifact {
  id             String   @id @default(cuid())
  visitId        String
  kind           String
  label          String
  mimeType       String
  sourceName     String?
  storageKey     String?
  extractedText  String?
  summary        String
  structuredJson String?
  createdAt      DateTime @default(now())

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@index([kind])
  @@index([createdAt])
}

model ShareLink {
  id        String    @id @default(cuid())
  visitId   String
  patientId String
  token     String    @unique
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  visit   Visit   @relation(fields: [visitId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([visitId])
}

model Appointment {
  id             String   @id @default(cuid())
  visitId        String
  patientId      String
  clinicianId    String
  sourceActionId String?  @unique
  title          String
  scheduledFor   DateTime
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  visit     Visit   @relation(fields: [visitId], references: [id], onDelete: Cascade)
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinician User    @relation("ClinicianAppointments", fields: [clinicianId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@index([patientId])
  @@index([clinicianId])
  @@index([scheduledFor])
}

model CarePlanItem {
  id             String    @id @default(cuid())
  visitId        String
  patientId      String
  clinicianId    String
  sourceActionId String?   @unique
  title          String
  details        String?
  dueAt          DateTime?
  status         String    @default("pending")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  visit     Visit   @relation(fields: [visitId], references: [id], onDelete: Cascade)
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinician User    @relation("ClinicianCarePlanItems", fields: [clinicianId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@index([patientId])
  @@index([clinicianId])
  @@index([dueAt])
}

model GeneratedReport {
  id          String   @id @default(cuid())
  visitId     String
  patientId   String
  clinicianId String
  title       String
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  visit     Visit   @relation(fields: [visitId], references: [id], onDelete: Cascade)
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinician User    @relation("ClinicianGeneratedReports", fields: [clinicianId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@index([patientId])
  @@index([clinicianId])
  @@index([createdAt])
}

model ReconciliationRun {
  id                      String   @id @default(cuid())
  patientId               String
  visitId                 String
  clinicianId             String
  status                  String   @default("running")
  overallConfidence       Int?
  consensusSummary        String?
  supportedClaimsJson     String?
  conflictsJson           String?
  unresolvedQuestionsJson String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  patient      Patient                     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visit        Visit                       @relation(fields: [visitId], references: [id], onDelete: Cascade)
  clinician    User                        @relation("ClinicianReconciliationRuns", fields: [clinicianId], references: [id], onDelete: Cascade)
  agentOutputs ReconciliationAgentOutput[]
  actions      ReconciliationAction[]

  @@index([patientId])
  @@index([visitId])
  @@index([clinicianId])
  @@index([status])
  @@index([createdAt])
}

model ReconciliationAgentOutput {
  id            String   @id @default(cuid())
  runId         String
  agentKey      String
  status        String   @default("completed")
  summary       String?
  confidence    Int?
  claimsJson    String?
  citationsJson String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  run ReconciliationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, agentKey])
  @@index([runId])
  @@index([agentKey])
}

model ReconciliationAction {
  id                String   @id @default(cuid())
  runId             String
  patientId         String
  visitId           String
  clinicianId       String
  kind              String
  title             String
  details           String?
  rationale         String?
  payloadJson       String?
  status            String   @default("suggested")
  appliedRecordType String?
  appliedRecordId   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  run       ReconciliationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  patient   Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visit     Visit             @relation(fields: [visitId], references: [id], onDelete: Cascade)
  clinician User              @relation("ClinicianReconciliationActions", fields: [clinicianId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([patientId])
  @@index([visitId])
  @@index([clinicianId])
  @@index([status])
}
